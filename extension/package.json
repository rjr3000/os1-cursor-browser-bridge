{
  "name": "os1-cursor-browser-bridge",
  "displayName": "os1 Cursor Browser Bridge",
  "description": "HTTP API for Cursor IDE embedded browser — script login without Agent (os1 x_cli)",
  "version": "0.5.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.74.0"
  },
  "extensionKind": ["workspace", "ui"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "os1BrowserBridge.openMockupPanel",
        "title": "os1 Browser Bridge: Open Mockup Panel (after CSS)"
      },
      {
        "command": "os1BrowserBridge.createScriptSession",
        "title": "os1 Browser Bridge: Create Script Session"
      },
      {
        "command": "os1BrowserBridge.captureAgentContext",
        "title": "os1 Browser Bridge: Capture Agent Context"
      },
      {
        "command": "os1BrowserBridge.enableMockupMode",
        "title": "os1 Browser Bridge: Enable Mockup Mode"
      },
      {
        "command": "os1BrowserBridge.disableMockupMode",
        "title": "os1 Browser Bridge: Disable Mockup Mode"
      },
      {
        "command": "os1BrowserBridge.duplicateElement",
        "title": "os1 Browser Bridge: Duplicate Element"
      },
      {
        "command": "os1BrowserBridge.addImageContainer",
        "title": "os1 Browser Bridge: Add Image Container"
      },
      {
        "command": "os1BrowserBridge.listMockupElements",
        "title": "os1 Browser Bridge: List Mockup Elements"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "os1BrowserBridgeSidebar",
          "title": "os1 Mockup",
          "icon": "$(paintcan)"
        }
      ]
    },
    "views": {
      "os1BrowserBridgeSidebar": [
        {
          "type": "webview",
          "id": "os1BrowserBridge.mockupSidebar",
          "name": "Mockup",
          "when": "true"
        }
      ]
    }
  }
}
